/* pages/index/index.wxss */

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  margin: -20rpx -20rpx 20rpx 0;
  border-radius: 0 0 40rpx 40rpx;
}

.greeting {
  flex: 1;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.avatar-wrapper {
  margin-left: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

/* 推荐区域 */
.section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #B5A6E6;
}

/* 旅伴卡片 */
.travel-mate-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  box-shadow: 0 4rpx 12rpx rgba(181, 166, 230, 0.15);
}

.mate-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.mate-info {
  flex: 1;
}

.mate-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.mate-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.match-rate {
  font-size: 24rpx;
  color: #B5A6E6;
  background: rgba(181, 166, 230, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.mate-destination {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.mate-date {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.mate-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  background: rgba(181, 166, 230, 0.1);
  color: #B5A6E6;
}
