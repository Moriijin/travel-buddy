/* pages/index/index.wxss */
/* 搭伴游首页 - 与 preview-enhanced.html 一致的设计系统 */

/* ===== 顶部导航 ===== */
.header {
  background: var(--gradient-primary);
  color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.city-text {
  font-size: 32rpx;
  font-weight: 600;
}

.header-right {
  display: flex;
  align-items: center;
}

.icon-btn {
  font-size: 40rpx;
  padding: 8rpx;
  transition: transform 0.2s;
}

.icon-btn:active {
  transform: scale(1.2);
}

/* ===== 欢迎回来区域 ===== */
.welcome-back {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--card-bg);
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: var(--shadow);
  margin: 0 0 24rpx 0;
  transition: transform 0.2s;
}

.welcome-back:active {
  transform: scale(0.98);
}

.welcome-avatar-wrapper {
  flex-shrink: 0;
}

.welcome-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 6rpx solid var(--lavender);
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
}

.welcome-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ===== 心情选择区 ===== */
.mood-section {
  margin: 0 32rpx 24rpx;
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: var(--shadow);
}

.mood-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
}

.mood-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 16rpx;
  border-radius: 32rpx;
  transition: transform 0.2s, background 0.2s, border-color 0.2s;
  border: 4rpx solid transparent;
}

.mood-item:active {
  transform: scale(0.9);
}

.mood-item.active {
  border-color: var(--lavender);
  background: rgba(197, 184, 230, 0.15);
}

.mood-icon {
  font-size: 56rpx;
  transition: transform 0.3s;
}

.mood-item:active .mood-icon {
  transform: scale(1.3) rotate(10deg);
}

.mood-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 行程分类摘要 ===== */
.trip-summary {
  margin: 0 32rpx 24rpx;
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.trip-summary::-webkit-scrollbar {
  display: none;
}

.trip-summary-card {
  flex: 1;
  min-width: 160rpx;
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
  transition: transform 0.2s;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.trip-summary-card:active {
  transform: scale(0.96);
}

.trip-summary-card.ongoing {
  border-left: 8rpx solid var(--mint);
}

.trip-summary-card.upcoming {
  border-left: 8rpx solid var(--sky);
}

.trip-summary-card.completed {
  border-left: 8rpx solid var(--text-light);
}

.ts-emoji {
  font-size: 56rpx;
}

.ts-count {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.ts-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  overflow-x: auto;
  background: var(--card-bg);
  margin: 0 32rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: var(--shadow);
  white-space: nowrap;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-item {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: rgba(197, 184, 230, 0.15);
  color: var(--text-secondary);
  flex-shrink: 0;
  transition: all 0.2s;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item.active {
  background: var(--gradient-primary);
  color: #ffffff;
}

/* ===== 为你推荐标题行 ===== */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background: rgba(197, 184, 230, 0.2);
  color: #9575CD;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.refresh-btn:active {
  transform: scale(0.95);
}

.refresh-icon {
  display: inline-block;
  font-size: 28rpx;
}

.refresh-icon.spinning {
  animation: spin 0.6s ease;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== 搭子卡片列表 ===== */
.buddy-list {
  padding: 0 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.buddy-card {
  background: var(--card-bg);
  border-radius: 48rpx;
  padding: 32rpx;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
}

.buddy-card:active {
  transform: scale(0.98);
}

/* 卡片顶部渐变条 */
.buddy-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: var(--gradient-warm);
}

/* 卡片头部：距离 + 匹配度 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 24rpx;
}

.card-distance {
  color: var(--text-light);
}

.card-match {
  color: #FF8A80;
  font-weight: 600;
  background: rgba(255, 138, 128, 0.15);
  padding: 4rpx 20rpx;
  border-radius: 24rpx;
}

/* 卡片主体：头像 + 信息 */
.card-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.buddy-card .avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.buddy-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid var(--lavender);
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
}

.buddy-card .verified {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--mint);
  color: #4CAF50;
  font-size: 22rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.buddy-card .info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.age {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.gender {
  font-size: 24rpx;
}

.gender.male {
  color: #7B9FFF;
}

.gender.female {
  color: #FF8A80;
}

.signature {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 标签 */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 2rpx dashed var(--text-light);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.9);
}

.btn-pass {
  color: var(--text-light);
}

.btn-like {
  color: #FF8A80;
}

.btn-like.liked {
  animation: heartBeat 0.5s ease;
  color: #FF4081;
}

.btn-sayhi {
  color: #9575CD;
  background: rgba(197, 184, 230, 0.2);
}

.btn-icon {
  font-size: 40rpx;
  transition: transform 0.3s;
}

.action-btn:active .btn-icon {
  transform: scale(1.4);
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  25% { transform: scale(1.3); }
  50% { transform: scale(1); }
  75% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
