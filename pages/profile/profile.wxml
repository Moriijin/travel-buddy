<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户资料头部 - 渐变紫色背景 -->
  <view class="profile-header" bindtap="goToEditProfile">
    <view class="avatar-wrapper">
      <view class="avatar">
        <text wx:if="{{userInfo.name}}">{{userInfo.name.substring(0, 1)}}</text>
        <text wx:else>我</text>
      </view>
    </view>
    <view class="nickname">{{userInfo.name || '旅行小达人'}}</view>
    <view class="city">📍 {{userInfo.city || '北京'}}</view>
  </view>

  <!-- 信用分卡片 -->
  <view class="credit-card" bindtap="showCreditDetail">
    <view class="credit-header">
      <text class="credit-label">信用分</text>
      <text class="credit-score">{{userInfo.creditScore || 180}}</text>
    </view>
    <view class="credit-bar">
      <view class="credit-fill" style="width: {{(userInfo.creditScore || 180) / 300 * 100}}%"></view>
    </view>
  </view>

  <!-- 统计卡片行 -->
  <view class="stats-row">
    <view class="stat-mini" bindtap="goToMyTrips">
      <text class="stat-label">👣 行程数</text>
      <text class="stat-value">{{userInfo.travelCount || 4}}</text>
    </view>
    <view class="stat-mini" bindtap="goToMyBuddies">
      <text class="stat-label">👥 认识搭子</text>
      <text class="stat-value">{{userInfo.matchCount || 8}}</text>
    </view>
    <view class="stat-mini" bindtap="showRating">
      <text class="stat-label">⭐ 好评率</text>
      <text class="stat-value">{{userInfo.rating || '95%'}}</text>
    </view>
  </view>

  <!-- 菜单组1: 主要功能 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyTrips">
      <text class="menu-icon">🏕️</text>
      <text class="menu-text">我的行程</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToDiary">
      <text class="menu-icon">📝</text>
      <text class="menu-text">旅行日记</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMessages">
      <text class="menu-icon">🔔</text>
      <text class="menu-text">消息通知</text>
      <view class="item-badge" wx:if="{{userInfo.unreadCount > 0}}">{{userInfo.unreadCount}}</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 菜单组2: 其他功能 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
