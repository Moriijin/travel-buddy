/* pages/profile/profile.wxss */
/* 匹配 preview-enhanced.html 设计风格 */

/* ===== 用户资料头部 ===== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
  background: var(--gradient-primary);
  color: #ffffff;
  border-radius: 0 0 60rpx 60rpx;
  cursor: pointer;
  transition: opacity 0.2s;
}

.profile-header:active {
  opacity: 0.9;
}

.avatar-wrapper {
  margin-bottom: 24rpx;
}

.profile-header .avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: bold;
}

.profile-header .nickname {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.profile-header .city {
  font-size: 26rpx;
  opacity: 0.9;
}

/* ===== 信用分卡片 ===== */
.credit-card {
  margin: -40rpx 32rpx 32rpx;
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform 0.2s;
}

.credit-card:active {
  transform: scale(0.98);
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.credit-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.credit-score {
  font-size: 48rpx;
  font-weight: 700;
  color: #9575CD;
}

.credit-bar {
  height: 16rpx;
  background: rgba(197, 184, 230, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
}

.credit-fill {
  height: 100%;
  background: var(--gradient-primary);
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

/* ===== 统计卡片行 ===== */
.stats-row {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.stat-mini {
  flex: 1;
  background: var(--card-bg);
  border-radius: 32rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform 0.2s;
}

.stat-mini:active {
  transform: scale(0.95);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ===== 菜单卡片 ===== */
.menu-section {
  background: var(--card-bg);
  border-radius: 40rpx;
  margin: 0 32rpx 32rpx;
  padding: 0 32rpx;
  box-shadow: var(--shadow);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid rgba(197, 184, 230, 0.15);
  cursor: pointer;
  transition: opacity 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  opacity: 0.7;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  color: var(--text-light);
  font-size: 28rpx;
}

/* ===== 未读徽标 ===== */
.item-badge {
  background: #FF8A80;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  margin-right: 12rpx;
}
