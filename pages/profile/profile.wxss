/* pages/profile/profile.wxss */

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  margin: -20rpx -20rpx 20rpx 0;
  border-radius: 0 0 40rpx 40rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 64rpx;
  font-weight: bold;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.edit-avatar-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.basic-info {
  text-align: center;
}

.name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.name-input {
  display: block;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 10rpx;
}

.age-gender {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.age {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.age-input {
  width: 120rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  text-align: center;
}

.gender {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(181, 166, 230, 0.15);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-edit {
  font-size: 26rpx;
  color: #B5A6E6;
}

.bio-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.bio-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(181, 166, 230, 0.1);
  color: #B5A6E6;
  font-size: 26rpx;
}

.delete-tag {
  margin-left: 10rpx;
  font-size: 32rpx;
  color: #999;
}

.add-tag-btn {
  font-size: 26rpx;
  color: #B5A6E6;
  padding: 8rpx 20rpx;
  border: 2rpx dashed #B5A6E6;
  border-radius: 40rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #B5A6E6;
  margin-bottom: 8rpx;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #eee;
}

/* 操作按钮 */
.actions {
  padding: 40rpx 0;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  background: #ffffff;
  color: #B5A6E6;
  border: 2rpx solid #B5A6E6;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.btn-link {
  width: 100%;
  background: transparent;
  color: #999;
  border: none;
  padding: 20rpx;
  font-size: 28rpx;
}
