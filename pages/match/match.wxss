/* pages/match/match.wxss */

.page-match {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  padding: 0 32rpx 40rpx;
}

/* ===== 筛选条件 ===== */
.filters {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  margin: 24rpx 32rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--bg);
  border-radius: 32rpx;
  transition: all 0.2s;
}

.filter-item:active {
  transform: scale(0.97);
  background: rgba(197, 184, 230, 0.15);
}

.filter-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.filter-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.filter-arrow {
  font-size: 36rpx;
  color: var(--text-light);
  margin-left: 10rpx;
}

/* ===== Buddy Card ===== */
.match-area {
  margin-top: 10rpx;
}

.buddy-card {
  position: relative;
  background: var(--card-bg);
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
  margin: 0 0rpx 40rpx;
  transition: box-shadow 0.3s;
}

/* 顶部渐变条 */
.card-gradient-top {
  height: 180rpx;
  background: var(--gradient-primary);
  position: relative;
  border-radius: 48rpx 48rpx 0 0;
}

.card-gradient-top::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, var(--card-bg));
}

/* 卡片顶部 - 头像 + 身份信息 */
.card-top {
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0 40rpx 0;
  margin-top: -80rpx;
  z-index: 1;
  gap: 28rpx;
}

.card-top .avatar-wrapper {
  flex-shrink: 0;
  margin-right: 0;
}

.card-top .avatar-lg {
  border-color: rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(197, 184, 230, 0.4);
}

.avatar-text {
  font-size: 56rpx;
  font-weight: 700;
}

/* 身份信息 */
.card-identity {
  flex: 1;
  padding-bottom: 10rpx;
}

.identity-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.age {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.gender {
  font-size: 24rpx;
  color: var(--text-light);
  padding: 4rpx 16rpx;
  background: var(--bg);
  border-radius: 20rpx;
}

.match-score-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: var(--gradient-primary);
  border-radius: 32rpx;
}

.score-text {
  font-size: 24rpx;
  color: white;
  font-weight: 600;
}

/* 签名 */
.card-bio {
  margin: 30rpx 40rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  font-style: italic;
}

/* 行程信息 */
.trip-info {
  display: flex;
  gap: 30rpx;
  margin: 24rpx 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(197, 184, 230, 0.2);
  border-bottom: 1rpx solid rgba(197, 184, 230, 0.2);
}

.trip-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.trip-icon {
  font-size: 28rpx;
}

.trip-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 彩色标签 */
.candidate-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 0 40rpx 36rpx;
}

.tag {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 标签配色 - 对应 design system 颜色 */
.tag-color-0 {
  background: rgba(184, 230, 208, 0.45);
  color: #5DAF8E;
}

.tag-color-1 {
  background: rgba(197, 184, 230, 0.4);
  color: #9575CD;
}

.tag-color-2 {
  background: rgba(255, 184, 163, 0.4);
  color: #E07A5F;
}

.tag-color-3 {
  background: rgba(163, 207, 255, 0.4);
  color: #5B9BD5;
}

.tag-color-4 {
  background: rgba(255, 184, 198, 0.4);
  color: #D96B8A;
}

.tag-color-5 {
  background: rgba(255, 240, 163, 0.5);
  color: #C9A832;
}

/* ===== 匹配中状态 ===== */
.matching-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 40rpx;
}

.spinner-ring {
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid rgba(197, 184, 230, 0.2);
  border-top-color: var(--lavender);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.spinner-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 20rpx;
  background: var(--lavender);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
}

.matching-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.matching-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 50rpx;
}

.btn-start-match {
  width: 80%;
  max-width: 500rpx;
  background: var(--gradient-primary);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(197, 184, 230, 0.4);
}

/* ===== 操作按钮 ===== */
.action-buttons {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  padding: 20rpx 40rpx 0;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  border-radius: 40rpx;
  transition: transform 0.2s, box-shadow 0.2s;
}

.action-btn:active {
  transform: scale(0.93);
}

.btn-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
  line-height: 1;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 跳过 - 灰色 */
.skip-btn {
  background: var(--card-bg);
  border: 2rpx solid rgba(184, 176, 204, 0.3);
  box-shadow: var(--shadow);
}

.skip-btn .btn-icon {
  color: var(--text-light);
}

.skip-btn .btn-text {
  color: var(--text-secondary);
}

/* 喜欢 - 红色 */
.like-btn {
  background: var(--card-bg);
  border: 2rpx solid rgba(255, 106, 106, 0.3);
  box-shadow: var(--shadow);
}

.like-btn .btn-icon {
  color: #FF6A6A;
}

.like-btn .btn-text {
  color: #FF6A6A;
}

/* 打招呼 - 紫色背景 */
.greet-btn {
  background: var(--gradient-primary);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(197, 184, 230, 0.35);
}

.greet-btn .btn-icon {
  color: white;
}

.greet-btn .btn-text {
  color: white;
}
