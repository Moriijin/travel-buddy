<!--pages/match/match.wxml-->
<view class="container">
  <!-- 筛选条件 -->
  <view class="filters card">
    <view class="filter-item" bindtap="selectDestination">
      <text class="filter-label">目的地</text>
      <text class="filter-value">{{filters.destination || '选择目的地'}}</text>
    </view>
    <view class="filter-item" bindtap="selectTravelDate">
      <text class="filter-label">出行时间</text>
      <text class="filter-value">{{filters.travelDate || '选择时间'}}</text>
    </view>
  </view>

  <!-- 匹配区域 -->
  <view class="match-area">
    <view class="candidate-card" wx:if="{{currentCandidate && !isMatching}}">
      <view class="candidate-avatar">
        <text>{{currentCandidate.name.substring(0, 1)}}</text>
      </view>
      <view class="candidate-info">
        <view class="candidate-header">
          <text class="candidate-name">{{currentCandidate.name}}</text>
          <view class="match-score">{{currentCandidate.matchScore}}%匹配</view>
        </view>
        <view class="candidate-detail">📍 {{currentCandidate.destination}}</view>
        <view class="candidate-detail">📅 {{currentCandidate.travelDate}}</view>
        <view class="candidate-detail">🏷️ {{currentCandidate.gender}}</view>
        <view class="candidate-bio">{{currentCandidate.bio}}</view>
        <view class="candidate-tags">
          <view class="tag" wx:for="{{currentCandidate.interests}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
    </view>

    <!-- 匹配中状态 -->
    <view class="matching-status" wx:if="{{isMatching}}">
      <view class="loading-spinner">🔍</view>
      <text class="matching-text">正在为你匹配最佳旅伴...</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons" wx:if="{{currentCandidate && !isMatching}}">
      <button class="btn-skip" bindtap="skipCandidate">跳过</button>
      <button class="btn-like" bindtap="likeCandidate">喜欢</button>
      <button class="btn-details" bindtap="viewDetails">详情</button>
    </view>
  </view>

  <!-- 开始匹配按钮 -->
  <button class="btn-start-match" bindtap="startMatching" wx:if="{{!currentCandidate && !isMatching}}">开始匹配</button>
</view>
