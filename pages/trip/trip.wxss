.page { min-height: 100vh; background: var(--bg); }

.trip-tabs {
  display: flex;
  background: var(--white);
  padding: 20rpx 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: var(--primary);
  border-bottom-color: var(--primary);
  font-weight: 500;
}

.publish-btn {
  margin: 20rpx 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: var(--white);
  border-radius: 20rpx;
  text-align: center;
  font-size: 30rpx;
}

.publish-btn .icon { font-size: 36rpx; margin-right: 8rpx; }

.trip-list { padding: 0 24rpx 20rpx; }

.trip-card {
  background: var(--white);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.trip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.trip-title { font-size: 30rpx; font-weight: 500; }

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(0,230,118,0.1);
  color: var(--accent-green);
}

.status-tag.enrolling {
  background: rgba(0,180,255,0.1);
  color: var(--secondary);
}

.trip-route {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.trip-route .arrow { margin: 0 12rpx; color: var(--primary); }

.trip-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-light);
}

.trip-tags { margin-bottom: 16rpx; }

.trip-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
}

.author-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.join-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-light));
  color: var(--white);
  border-radius: 30rpx;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: var(--text-light);
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-hint { font-size: 24rpx; margin-top: 12rpx; }
