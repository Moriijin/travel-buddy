/* 发现页样式 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--white);
}

.search-bar .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 筛选面板 */
.filter-panel {
  padding: 20rpx 24rpx;
  background: var(--white);
  margin-bottom: 20rpx;
}

.filter-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: #F0F0F0;
  color: var(--text-secondary);
}

.filter-chip.active {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-light));
  color: var(--white);
}

/* 热门话题 */
.topics-section {
  padding: 0 24rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.more {
  font-size: 24rpx;
  color: var(--primary);
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.topic-card {
  display: flex;
  align-items: center;
  background: var(--white);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.topic-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, var(--primary-light), var(--secondary-light));
}

.topic-info {
  flex: 1;
}

.topic-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.topic-posts {
  font-size: 24rpx;
  color: var(--text-light);
}
