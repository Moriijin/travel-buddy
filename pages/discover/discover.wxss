/* 发现页样式 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== 内容区域 ===== */
.content {
  padding: 24rpx 32rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--card-bg);
  border-radius: 40rpx;
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-input::placeholder {
  color: var(--text-light);
}

/* ===== 筛选面板 ===== */
.filter-panel {
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: var(--shadow);
  margin-bottom: 32rpx;
}

.filter-section {
  margin-bottom: 28rpx;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* ===== 热门话题 ===== */
.topics-section {
  padding-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.more {
  font-size: 24rpx;
  color: #9575CD;
  padding: 8rpx 16rpx;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topic-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 24rpx 32rpx;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}

.topic-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-hover);
}

.topic-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  margin-right: 24rpx;
  background: var(--gradient-fresh);
  flex-shrink: 0;
}

.topic-info {
  flex: 1;
  min-width: 0;
}

.topic-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic-posts {
  font-size: 24rpx;
  color: var(--text-light);
}

.topic-arrow {
  font-size: 40rpx;
  color: var(--text-light);
  margin-left: 16rpx;
  flex-shrink: 0;
}
