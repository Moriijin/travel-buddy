/* pages/chat/chat.wxss */

.page-chat {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
}

/* ===== 对话列表视图 ===== */
.chat-list-view {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.conversation-list {
  flex: 1;
  padding: 20rpx 32rpx;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  background: var(--card-bg);
  border-radius: 36rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}

.conversation-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-hover);
}

.conversation-item .avatar-wrapper {
  position: relative;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.conversation-item .avatar {
  width: 112rpx;
  height: 112rpx;
  border: none;
  border-radius: 50%;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
}

.avatar-text-sm {
  font-size: 24rpx;
  font-weight: 600;
  color: white;
}

/* 在线状态点 */
.online-dot {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background: #66BB6A;
  border: 4rpx solid var(--card-bg);
  border-radius: 50%;
}

.conv-info {
  flex: 1;
  min-width: 0;
}

.conv-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.conv-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.conv-time {
  font-size: 22rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

.conv-last-message {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.last-msg-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 聊天窗口 ===== */
.chat-window {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* 聊天头部 - 紫色渐变 */
.chat-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--gradient-primary);
  color: white;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-btn {
  font-size: 44rpx;
  color: white;
  padding: 0 20rpx;
  line-height: 1;
  transition: transform 0.2s;
}

.back-btn:active {
  transform: scale(1.15);
}

.chat-title-area {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  justify-content: center;
}

.chat-title {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
}

.chat-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-more {
  font-size: 40rpx;
  color: white;
  padding: 0 8rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

.message-date {
  text-align: center;
  margin-bottom: 30rpx;
}

.message-date text {
  font-size: 22rpx;
  color: var(--text-light);
  background: rgba(184, 176, 204, 0.15);
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  gap: 16rpx;
}

/* 自己消息 - 靠右对齐 */
.message-item.self {
  flex-direction: row-reverse;
  justify-content: flex-end;
}

.message-item.other {
  flex-direction: row;
}

/* 消息头像 - 双方都有 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
}

/* 自己消息头像 */
.message-item.self .msg-avatar {
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  border: none;
}

/* 对方消息头像 */
.message-item.other .msg-avatar {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  align-self: flex-end;
  border: 3rpx solid var(--lavender);
}

.other-avatar {
  border: 3rpx solid var(--lavender);
}

.self-avatar {
  background: var(--gradient-primary) !important;
  border: none;
}

/* 消息气泡 */
.message-bubble {
  max-width: 550rpx;
  padding: 24rpx 32rpx;
  position: relative;
  word-wrap: break-word;
}

/* 自己消息 - 紫色渐变气泡 */
.message-item.self .message-bubble {
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  color: white;
  border-radius: 32rpx 32rpx 8rpx 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(163, 207, 255, 0.3);
}

/* 对方消息 - 白色卡片气泡 */
.message-item.other .message-bubble {
  background: var(--card-bg);
  color: var(--text-primary);
  border-radius: 32rpx 32rpx 32rpx 8rpx;
  box-shadow: var(--shadow);
}

.message-content {
  font-size: 30rpx;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

.message-time {
  display: block;
  font-size: 20rpx;
  margin-top: 10rpx;
  opacity: 0.65;
  text-align: right;
}

/* ===== 输入栏 ===== */
.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: var(--card-bg);
  border-top: 1px solid rgba(197, 184, 230, 0.15);
  gap: 20rpx;
}

.input-extras {
  flex-shrink: 0;
}

.extra-btn {
  font-size: 40rpx;
  color: var(--text-light);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg);
  transition: all 0.2s;
}

.extra-btn:active {
  transform: scale(0.9);
  background: rgba(197, 184, 230, 0.2);
}

.input-wrapper {
  flex: 1;
}

.input-field {
  width: 100%;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: none;
  transition: background 0.2s;
}

.input-field:focus {
  background: rgba(197, 184, 230, 0.1);
}

.send-btn {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(197, 184, 230, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.send-btn.active {
  background: var(--gradient-primary);
  box-shadow: 0 4rpx 16rpx rgba(163, 207, 255, 0.4);
}

.send-btn:active {
  transform: scale(0.9);
}

.send-icon {
  font-size: 32rpx;
  color: var(--text-light);
  font-weight: 700;
  line-height: 1;
  transform: rotate(-45deg);
}

.send-btn.active .send-icon {
  color: white;
}
