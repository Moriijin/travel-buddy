/* pages/chat/chat.wxss */

.conversation-list {
  padding-top: 20rpx;
}

.conversation-item {
  display: flex;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.conv-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.conv-info {
  flex: 1;
}

.conv-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.conv-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.conv-time {
  font-size: 24rpx;
  color: #999;
}

.conv-last-message {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.conv-last-message text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-badge {
  min-width: 40rpx;
  height: 40rpx;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  margin-left: 10rpx;
}

/* 聊天窗口 */
.chat-window {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.chat-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  color: #ffffff;
}

.back-btn {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: #ffffff;
}

.chat-title {
  font-size: 32rpx;
  font-weight: 500;
  flex: 1;
}

.message-list {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
}

.message-item.self {
  justify-content: flex-end;
}

.message-item.other {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 30rpx;
  border-radius: 24rpx;
  position: relative;
}

.message-item.self .message-bubble {
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.message-item.other .message-bubble {
  background: #ffffff;
  color: #333;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.message-content {
  font-size: 28rpx;
  line-height: 1.6;
  word-wrap: break-word;
}

.message-time {
  display: block;
  font-size: 20rpx;
  margin-top: 8rpx;
  opacity: 0.7;
}

/* 输入框 */
.chat-input {
  display: flex;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.input-field {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}
