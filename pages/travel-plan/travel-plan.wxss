/* pages/travel-plan/travel-plan.wxss 创建行程表单 */

/* ===== 页面容器 ===== */
.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 180rpx;
}

/* ===== 渐变头部 ===== */
.header-wrapper {
  background: var(--gradient-primary);
  box-shadow: 0 4rpx 20rpx rgba(197, 184, 230, 0.3);
}

.status-bar-spacer {
  height: env(safe-area-inset-top);
  min-height: 0;
}

.header {
  background: var(--gradient-primary);
  padding: 24rpx 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left,
.header-right {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  transition: background 0.2s;
}

.header-left:active,
.header-right:active {
  background: rgba(255, 255, 255, 0.2);
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  flex: 1;
  text-align: center;
}

.publish-link {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

/* ===== 表单区域 ===== */
.form-area {
  padding: 24rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 行程名称输入框 ===== */
.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  border: 4rpx solid rgba(197, 184, 230, 0.25);
  background: var(--card-bg);
  font-size: 30rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow);
  transition: border-color 0.25s, box-shadow 0.25s;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--lavender);
  box-shadow: var(--shadow-hover);
}

/* ===== 双列布局 ===== */
.dual-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dual-item {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 32rpx;
  border: 4rpx solid rgba(197, 184, 230, 0.25);
  padding: 0 24rpx;
  box-shadow: var(--shadow);
  transition: border-color 0.25s;
}

.dual-item:focus-within {
  border-color: var(--lavender);
}

.dual-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.dual-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 100%;
}

.dual-separator {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--lavender);
  flex-shrink: 0;
  padding: 0 4rpx;
}

/* ===== 双列选择器 ===== */
.dual-picker {
  flex: 1;
}

.dual-picker-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 32rpx;
  border: 4rpx solid rgba(197, 184, 230, 0.25);
  padding: 0 24rpx;
  box-shadow: var(--shadow);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  min-width: 0;
}

.placeholder-style {
  color: var(--text-light);
}

/* ===== 行程描述 ===== */
.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 28rpx 32rpx;
  border-radius: 32rpx;
  border: 4rpx solid rgba(197, 184, 230, 0.25);
  background: var(--card-bg);
  font-size: 28rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow);
  line-height: 1.6;
  transition: border-color 0.25s, box-shadow 0.25s;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--lavender);
  box-shadow: var(--shadow-hover);
}

.textarea-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 10rpx;
  padding-right: 8rpx;
}

/* ===== 标签选择 ===== */
.tag-scroll {
  white-space: nowrap;
  margin-top: 8rpx;
}

.tag-scroll-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 4rpx;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.25s;
  transform-origin: center;
}

.tag-chip:active {
  transform: scale(0.93);
}

/* 默认未选中态 */
.tag-chip {
  background: rgba(197, 184, 230, 0.12);
  color: var(--text-secondary);
  border: 3rpx solid rgba(197, 184, 230, 0.15);
}

/* 选中态 */
.tag-chip.tag-selected {
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(61, 53, 87, 0.12);
}

/* 各标签颜色 */
.tag-color-0.tag-selected { background: linear-gradient(135deg, #B8E6D0, #81D4B0); }
.tag-color-1.tag-selected { background: linear-gradient(135deg, #FFB8A3, #FF9A80); }
.tag-color-2.tag-selected { background: linear-gradient(135deg, #C5B8E6, #A78BFA); }
.tag-color-3.tag-selected { background: linear-gradient(135deg, #FFE0A3, #FFC857); }
.tag-color-4.tag-selected { background: linear-gradient(135deg, #A3CFFF, #82B1FF); }
.tag-color-5.tag-selected { background: linear-gradient(135deg, #FFB8C6, #FF9EB5); }
.tag-color-6.tag-selected { background: linear-gradient(135deg, #B8E6D0, #A3CFFF); }
.tag-color-7.tag-selected { background: linear-gradient(135deg, #FFB8A3, #C5B8E6); }
.tag-color-8.tag-selected { background: linear-gradient(135deg, #A3CFFF, #B8E6D0); }
.tag-color-9.tag-selected { background: linear-gradient(135deg, #C5B8E6, #FFB8C6); }

.tag-hint {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 12rpx;
  display: block;
}

/* ===== 底部发布按钮 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(248, 245, 255, 1) 60%, rgba(248, 245, 255, 0));
  z-index: 50;
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  background: var(--gradient-primary);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(197, 184, 230, 0.4);
  transition: transform 0.2s, box-shadow 0.2s;
  letter-spacing: 2rpx;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(197, 184, 230, 0.3);
}

.submit-btn::after {
  border: none;
}

/* ===== 占位符 ===== */
.input-placeholder,
.textarea-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
}
