/* pages/travel-plan/travel-plan.wxss */

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  margin: -20rpx -20rpx 20rpx 0;
  border-radius: 0 0 40rpx 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.create-btn {
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
}

/* 计划列表 */
.plan-list {
  padding-top: 20rpx;
}

.plan-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(181, 166, 230, 0.15);
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.plan-status {
  padding: 8rpx 16rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.status-active {
  background: #e6f7ff;
  color: #1890ff;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.plan-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

.plan-actions {
  display: flex;
  justify-content: flex-end;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}
