<!--pages/travel-plan/travel-plan.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="title">我的旅行计划</text>
    <view class="create-btn" bindtap="createPlan">+ 新建</view>
  </view>

  <!-- 计划列表 -->
  <view class="plan-list">
    <view class="plan-card" wx:for="{{plans}}" wx:key="id" bindtap="viewPlanDetail" data-id="{{item.id}}">
      <view class="plan-header">
        <text class="plan-title">{{item.title}}</text>
        <view class="plan-status status-{{item.status === '进行中' ? 'active' : 'pending'}}">{{item.status}}</view>
      </view>
      
      <view class="plan-info">
        <view class="info-item">
          <text class="info-icon">📍</text>
          <text class="info-text">{{item.destination}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">📅</text>
          <text class="info-text">{{item.startDate}} ~ {{item.endDate}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">💰</text>
          <text class="info-text">{{item.budget}}元/人</text>
        </view>
        <view class="info-item">
          <text class="info-icon">👥</text>
          <text class="info-text">{{item.participants}}/{{item.maxParticipants}} 人</text>
        </view>
      </view>

      <view class="plan-actions">
        <button class="btn-secondary" size="mini" bindtap="deletePlan" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{plans.length === 0}}">
    <view class="empty-icon">🗺️</view>
    <text class="empty-text">暂无旅行计划</text>
    <button class="btn-primary" bindtap="createPlan">创建第一个计划</button>
  </view>
</view>
