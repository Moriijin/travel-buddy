/* 搭伴游 - 全局设计系统 */
/* Design tokens from preview-enhanced.html */

page {
  --mint: #B8E6D0;
  --lavender: #C5B8E6;
  --peach: #FFB8A3;
  --butter: #FFE0A3;
  --sky: #A3CFFF;
  --rose: #FFB8C6;
  --lemon: #FFF3A3;
  --bg: #F8F5FF;
  --card-bg: #FFFFFF;
  --text-primary: #3D3557;
  --text-secondary: #7B7399;
  --text-light: #B8B0CC;
  --gradient-primary: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  --gradient-warm: linear-gradient(135deg, #FFB8A3, #FFE0A3);
  --gradient-fresh: linear-gradient(135deg, #B8E6D0, #A3CFFF);
  --shadow: 0 2rpx 12rpx rgba(61, 53, 87, 0.08);
  --shadow-hover: 0 4rpx 16rpx rgba(61, 53, 87, 0.12);

  background-color: var(--bg);
  font-family: 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

/* ===== 通用容器 ===== */
.container {
  min-height: 100vh;
  background: var(--bg);
}

/* ===== 顶部导航 ===== */
.header {
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  color: white;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 24rpx;
}

.header .title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  text-align: center;
}

.header .icon-btn {
  font-size: 40rpx;
  padding: 8rpx;
  transition: transform 0.2s;
}

.header .icon-btn:active {
  transform: scale(1.2);
}

.header .back-btn {
  font-size: 44rpx;
  cursor: pointer;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: var(--shadow);
}

/* ===== 按钮系统 ===== */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: transform 0.2s, opacity 0.2s;
}

.btn:active {
  transform: scale(0.96);
}

.btn-primary {
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  color: white;
}

.btn-secondary {
  background: rgba(197, 184, 230, 0.2);
  color: #9575CD;
}

.btn-warm {
  background: linear-gradient(135deg, #FFB8A3, #FFE0A3);
  color: white;
}

.btn-block {
  display: block;
  width: 100%;
}

.btn-sm {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
}

/* ===== 标签/芯片 ===== */
.chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.chip:active {
  transform: scale(0.95);
}

.chip-default {
  background: rgba(197, 184, 230, 0.15);
  color: var(--text-secondary);
}

.chip-active {
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  color: white;
}

.chip-mint {
  background: rgba(184, 230, 208, 0.4);
  color: #66BB6A;
}

.chip-lavender {
  background: rgba(197, 184, 230, 0.4);
  color: #9575CD;
}

.chip-peach {
  background: rgba(255, 184, 163, 0.4);
  color: #FF8A65;
}

.chip-sky {
  background: rgba(163, 207, 255, 0.4);
  color: #64B5F6;
}

.chip-rose {
  background: rgba(255, 184, 198, 0.4);
  color: #F48FB1;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin: 4rpx;
}

/* ===== 头像系统 ===== */
.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid var(--lavender);
  background: linear-gradient(135deg, #C5B8E6, #A3CFFF);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  object-fit: cover;
}

.avatar-sm {
  width: 88rpx;
  height: 88rpx;
  border-width: 4rpx;
}

.avatar-xs {
  width: 64rpx;
  height: 64rpx;
  border-width: 4rpx;
}

.avatar-lg {
  width: 160rpx;
  height: 160rpx;
  border-width: 8rpx;
  border-color: rgba(255, 255, 255, 0.5);
}

.verified {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--mint);
  color: #4CAF50;
  font-size: 22rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

/* ===== 输入框 ===== */
.input-field {
  width: 100%;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  border: 4rpx solid rgba(197, 184, 230, 0.3);
  font-size: 28rpx;
  outline: none;
  transition: border-color 0.2s;
  font-family: inherit;
}

.input-field:focus {
  border-color: var(--lavender);
}

/* ===== 列表项 ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: var(--card-bg);
  transition: background 0.2s;
}

.list-item:active {
  background: rgba(197, 184, 230, 0.1);
}

.list-item .item-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.list-item .item-text {
  flex: 1;
  font-size: 28rpx;
}

.list-item .item-arrow {
  color: var(--text-light);
}

.list-item .item-badge {
  background: #FF8A80;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

/* ===== 分割线 ===== */
.divider {
  height: 16rpx;
  background: var(--bg);
}

.divider-line {
  height: 1rpx;
  border-top: 1rpx dashed var(--text-light);
  margin: 20rpx 0;
}

/* ===== 分区标题 ===== */
.section-title {
  padding: 0 32rpx;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title-row .section-title {
  padding: 0;
  margin-bottom: 0;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: none;
  background: rgba(197, 184, 230, 0.2);
  color: #9575CD;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.refresh-btn:active {
  transform: scale(0.95);
}

/* ===== 未读徽标 ===== */
.unread-badge {
  background: #FF8A80;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}

/* ===== 状态标签 ===== */
.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  background: rgba(184, 230, 208, 0.4);
  color: #66BB6A;
  font-weight: 500;
}

/* ===== 加载/空状态 ===== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-light);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: var(--text-light);
}

.empty-state image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 60rpx;
}

/* ===== 文本工具类 ===== */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); font-size: 24rpx; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-xxl { font-size: 48rpx; font-weight: 700; }

/* ===== 间距工具类 ===== */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* ===== Flex 布局 ===== */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.gap-10 { gap: 10rpx; }
.gap-20 { gap: 20rpx; }
