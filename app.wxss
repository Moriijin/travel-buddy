/* 全局样式 */

page {
  background-color: #F5F0FF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(181, 166, 230, 0.15);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  margin: 20rpx 0;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 次要按钮 */
.btn-secondary {
  background: #ffffff;
  color: #B5A6E6;
  border: 2rpx solid #B5A6E6;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  margin: 20rpx 0;
}

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B5A6E6, #E8B4F8);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin: 4rpx;
  background: rgba(181, 166, 230, 0.1);
  color: #B5A6E6;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

/* 文本工具类 */
.text-light {
  color: #999;
  font-size: 24rpx;
}

.text-bold {
  font-weight: bold;
}

.text-center {
  text-align: center;
}

/* 间距工具类 */
.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
